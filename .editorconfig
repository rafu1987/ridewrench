# EditorConfig is awesome: http://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
charset = utf-8
block_comment_start = /*
block_comment = *
block_comment_end = */

[*.php]
insert_final_newline = false
indent_size = 4

[*.rst]
indent_style = tab
insert_final_newline = false
indent_size = 3

[*.{txt,atom,xml,xlf,tmpl,ts,typoscript,tsconfig}]
insert_final_newline = false

[*.{md,markdown}]
trim_trailing_whitespace = false
indent_style = space
indent_size = 4

[{_.htaccess,.htaccess, .htaccess-dev}]
indent_style = tab
indent_size = 4

[*.json]
indent_style = tab
indent_size = 4

[*.html]
indent_style = tab
insert_final_newline = false

[{package.json,.travis.yml,bower.json}]
indent_style = space
indent_size = 2

[*.xlf]
indent_style = tab
indent_size = 4

[*.svg]
insert_final_newline = false
